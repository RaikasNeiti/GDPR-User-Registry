# GDPR User Registry - Environment Variables Example
# Copy to .env and customize for your environment

# ==================== Application ====================
NODE_ENV=development
PORT=3000

# ==================== Database ====================
DATABASE_URL=./data/users.db

# ==================== GDPR Compliance ====================
# How long to keep user data after deletion request (in days)
DATA_RETENTION_DAYS=365

# Grace period before permanent deletion (in days)
DELETION_GRACE_PERIOD_DAYS=30

# How long to retain audit logs (in days)
AUDIT_LOG_RETENTION_DAYS=1095

# ==================== Security ====================
# Bcrypt salt rounds (higher = more secure but slower)
# Recommended: 10-12 for production
BCRYPT_SALT_ROUNDS=10

# ==================== Email (Optional) ====================
# For sending notifications and password resets
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@gdpr-registry.com

# ==================== Admin Contacts ====================
# Data Protection Officer contact
DPO_EMAIL=dpo@gdpr-registry.com

# Privacy inquiries contact
PRIVACY_EMAIL=privacy@gdpr-registry.com

# Support contact
SUPPORT_EMAIL=support@gdpr-registry.com

# ==================== Logging ====================
# Log level: error, warn, info, debug, trace
LOG_LEVEL=info

# Log file path (optional)
LOG_FILE=/app/data/app.log

# ==================== Database Backups ====================
# Enable automatic backups
BACKUP_ENABLED=true

# Backup interval (in hours)
BACKUP_INTERVAL=24

# Keep backups for (in days)
BACKUP_RETENTION_DAYS=30

# ==================== API Configuration ====================
# Enable API documentation
API_DOCS_ENABLED=true

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==================== CORS Configuration ====================
# Allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ==================== Session Configuration ====================
# Session timeout (in milliseconds)
SESSION_TIMEOUT=3600000

# Session secret (should be random string in production)
SESSION_SECRET=your-random-secret-key-here

# ==================== Docker Specific ====================
# Container name (auto-generated but can be customized)
CONTAINER_NAME=gdpr-user-registry

# Restart policy: always, unless-stopped, no
RESTART_POLICY=unless-stopped

# ==================== Miscellaneous ====================
#Vault
VAULT_TOKEN=your-vault-token-here