# GDPR User Registry - Environment Variables Example
# Copy to .env and customize for your environment

# Application
NODE_ENV=development
PORT=3000

# Database configuration
# Either set DATABASE_URL or use the PG* variables below.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/gdpr
PGHOST=localhost
PGDATABASE=gdpr
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres

# GDPR retention settings
DATA_RETENTION_DAYS=365
DELETION_GRACE_PERIOD_DAYS=30
AUDIT_LOG_RETENTION_DAYS=1095

# Security
BCRYPT_SALT_ROUNDS=10
JWT_EXPIRES_IN=1h
DATA_ENCRYPTION_KEY=<generate-a-32-byte-hex-value>
JWT_SECRET=<generate-a-long-random-secret>

# Vault (optional)
VAULT_ADDR=https://localhost:8200
VAULT_TOKEN=replace-with-your-vault-token
VAULT_SECRET_PATH=secret/data/gdpr-app

# TLS Settings (only for testing)
# VAULT_TLS_INSECURE=false

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password

# Admin contacts
DPO_EMAIL=dpo@gdpr-registry.com
PRIVACY_EMAIL=privacy@gdpr-registry.com
SUPPORT_EMAIL=support@gdpr-registry.com

# Helper commands to generate secrets
# Generate DATA_ENCRYPTION_KEY:
# node -e "const s=require('libsodium-wrappers'); s.ready.then(()=>console.log(Buffer.from(s.randombytes_buf(32)).toString('hex')));"
#
# Generate JWT_SECRET:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"